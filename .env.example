# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hrisa_mux
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key
REFRESH_TOKEN_EXPIRES_IN=7d

# API Keys
YOUTUBE_API_KEY=your-youtube-api-key-here
SOUNDCLOUD_CLIENT_ID=your-soundcloud-client-id-here

# Storage Configuration
STORAGE_TYPE=local
# For S3 storage (production):
# STORAGE_TYPE=s3
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=hrisa-mux-uploads

# Server Configuration
API_PORT=3001
API_URL=http://localhost:3001
WEB_PORT=3000
WEB_URL=http://localhost:3000
NODE_ENV=development

# Upload Limits
MAX_FILE_SIZE=104857600
# 100MB in bytes
ALLOWED_FILE_TYPES=audio/mpeg,audio/mp4,audio/flac,audio/wav,audio/ogg

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
# 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Redis Cache TTL (in seconds)
CACHE_TTL_YOUTUBE=1800
# 30 minutes
CACHE_TTL_SOUNDCLOUD=1800
# 30 minutes
CACHE_TTL_METADATA=3600
# 1 hour
