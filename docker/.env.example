# Docker Environment Configuration
# Copy this file to .env and customize for your environment

# PostgreSQL Configuration
POSTGRES_DB=hrisa_mux
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# API Environment Variables
NODE_ENV=development
API_PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# Database Connection (use service name 'postgres' in Docker network)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/hrisa_mux

# Redis Connection (use service name 'redis' in Docker network)
REDIS_URL=redis://redis:6379

# JWT Configuration
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=dev-refresh-token-secret-change-in-production
REFRESH_TOKEN_EXPIRES_IN=7d

# YouTube API (Optional)
YOUTUBE_API_KEY=

# SoundCloud (Optional)
SOUNDCLOUD_CLIENT_ID=

# Storage Configuration
STORAGE_TYPE=local
MAX_FILE_SIZE=104857600
ALLOWED_FILE_TYPES=audio/mpeg,audio/mp4,audio/flac,audio/wav,audio/ogg

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cache TTL (seconds)
CACHE_TTL_YOUTUBE=1800
CACHE_TTL_SOUNDCLOUD=1800
CACHE_TTL_METADATA=3600

# Next.js Web App
NEXT_PUBLIC_API_URL=http://localhost:3001
